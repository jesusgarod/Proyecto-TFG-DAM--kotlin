<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#FFFFFF"
    tools:context=".DetallePacienteActivity">

    <TextView
        android:id="@+id/tvNombreDetalle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre del Paciente"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#2196F3"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        />

    <TextView
        android:id="@+id/tvSubtituloDetalle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Perfil del Paciente"
        android:textSize="16sp"
        android:textColor="#757575"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/tvNombreDetalle"
        app:layout_constraintStart_toStartOf="parent"
        />

    <Button
        android:id="@+id/btnAsignarEjercicio"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:text="Asignar Ejercicio"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#4CAF50"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtituloDetalle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />
    
    <Button
        android:id="@+id/btnVerEjerciciosPaciente"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:text="Ver / Borrar Ejercicios"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#FF9800"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnAsignarEjercicio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        />


























</androidx.constraintlayout.widget.ConstraintLayout>