<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/fondo"
    tools:context=".DetallePacienteActivity">

    <TextView
        android:id="@+id/tvNombreDetalle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre del Paciente"
        android:textSize="32sp"
        android:fontFamily="@font/abeezee_regular"
        android:textStyle="bold"
        android:textColor="@color/primario"
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <TextView
        android:id="@+id/tvSubtituloDetalle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Perfil del Paciente"
        android:textSize="16sp"
        android:textColor="@color/secundario"
        android:layout_marginTop="40dp"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@+id/tvNombreDetalle"
        app:layout_constraintStart_toStartOf="parent"
        />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAsignarEjercicio"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:text="Asignar Ejercicio"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="@color/terciario"

        app:cornerRadius="16dp"
        app:rippleColor="#80FFFFFF"

        app:icon="@drawable/ic_ejerc"
        app:iconGravity="textStart"
        app:iconSize="32dp"


        android:layout_marginTop="90dp"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtituloDetalle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />
    
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVerEjerciciosPaciente"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:text="Ver / Borrar Ejercicios"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="@color/terciario"

        app:cornerRadius="16dp"
        app:rippleColor="#80FFFFFF"

        android:layout_marginTop="62dp"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/btnAsignarEjercicio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        />


























</androidx.constraintlayout.widget.ConstraintLayout>