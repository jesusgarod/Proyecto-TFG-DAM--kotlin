<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="16dp"
    android:layout_margin="8dp"
    android:background="#F5F5F5"
    android:elevation="2dp">

    <TextView
        android:id="@+id/tvNombreEjercicioFisio"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Nombre del Ejercicio"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <TextView
        android:id="@+id/tvSeriesRepeticionesFisio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3 Series de 15 repeticiones"
        android:textSize="14sp"
        android:textColor="#4CAF50"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvNombreEjercicioFisio"
        app:layout_constraintStart_toStartOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>