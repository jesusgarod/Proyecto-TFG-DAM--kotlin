<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/fondo"
    tools:context=".MenuFisioActivity">

    <TextView
        android:id="@+id/tvBienvenidaFisio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¡Hola, Fisio"
        android:textSize="32dp"
        android:textStyle="bold"
        android:fontFamily="@font/abeezee_regular"
        android:textColor="@color/primario"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <TextView
        android:id="@+id/tvSubtituloFisio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Panel de Control"
        android:textSize="18sp"
        android:textColor="#757575"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvBienvenidaFisio"
        app:layout_constraintStart_toStartOf="parent"
        />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVerPacientes"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:text="Mis Pacientes"
        android:textSize="18sp"
        android:textStyle="bold"

        app:cornerRadius="16dp"
        app:backgroundTint="@color/terciario"
        app:rippleColor="#80FFFFFF"

        app:icon="@drawable/ic_ejerc"
        app:iconGravity="textStart"
        app:iconSize="32dp"

        android:layout_marginTop="90dp"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtituloFisio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAgendaCitas"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:text="Agenda de Citas"
        android:textSize="18sp"
        android:textStyle="bold"

        app:cornerRadius="16dp"
        app:backgroundTint="@color/terciario"
        app:rippleColor="#80FFFFFF"

        app:icon="@drawable/ic_cita"
        app:iconGravity="textStart"
        app:iconSize="32dp"

        android:layout_marginTop="62dp"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/btnVerPacientes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <Button
        android:id="@+id/btnCerrarSesionFisio"
        android:layout_width="250dp"
        android:layout_height="60dp"
        android:text="Cerrar Sesión"
        android:textSize="18sp"
        android:backgroundTint="@color/error50"
        android:layout_margin="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />



</androidx.constraintlayout.widget.ConstraintLayout>