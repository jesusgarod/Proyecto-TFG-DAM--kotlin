<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MenuPrincipalActivity"
    android:background="@color/fondo">

    <TextView
        android:id="@+id/tvBienvenida"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¡hola, paciente!"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/primario"
        android:fontFamily="@font/abeezee_regular"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"
        />

    <TextView
        android:id="@+id/tvPerfilEdad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:text="Edad: --"
        android:layout_marginTop="40dp"
        android:layout_marginStart="20dp"
        android:textColor="@color/secundario"
        app:layout_constraintTop_toBottomOf="@id/tvBienvenida"
        app:layout_constraintStart_toStartOf="parent"
        />

    <TextView
        android:id="@+id/tvPerfilTelefono"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:text="Teléfono: --"
        android:layout_marginTop="8dp"
        android:layout_marginStart="20dp"
        android:textColor="@color/secundario"
        app:layout_constraintTop_toBottomOf="@id/tvPerfilEdad"
        app:layout_constraintStart_toStartOf="parent"
        />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCitas"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:text="Mis Citas"
        android:textSize="18sp"

        app:cornerRadius="16dp"
        app:backgroundTint="@color/terciario"
        app:rippleColor="#80FFFFFF"

        app:icon="@drawable/ic_cita"
        app:iconGravity="textStart"
        app:iconSize="32dp"

        app:layout_constraintTop_toBottomOf="@id/tvPerfilTelefono"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="90dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEjercicios"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:text="Mis Ejercicios"

        app:cornerRadius="16dp"
        android:backgroundTint="@color/terciario"
        app:rippleColor="#80FFFFFF"

        app:icon="@drawable/ic_ejerc"
        app:iconGravity="textStart"
        app:iconSize="32dp"

        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@+id/btnCitas"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="62dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        />

    <Button
        android:id="@+id/btnCerrarSesion"
        android:layout_width="250dp"
        android:layout_height="60dp"
        android:text="Cerrar Sesión"
        android:textSize="18sp"
        android:backgroundTint="@color/error50"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        />




























</androidx.constraintlayout.widget.ConstraintLayout>