<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"

    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@color/terciario_item2"
    app:cardElevation="4dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvIconoPaciente"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="#E0E0E0"
            android:gravity="center"
            android:text="👤"
            android:textSize="24sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tvNombrePaciente"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nombre del Paciente"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="@id/tvIconoPaciente"
            app:layout_constraintStart_toEndOf="@id/tvIconoPaciente"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvEdadPaciente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="30 años"
            android:textSize="14sp"
            android:textColor="@color/primario"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/tvNombrePaciente"
            app:layout_constraintBottom_toBottomOf="@id/tvNombrePaciente"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvEmailPaciente"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="correo@paciente.com"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvNombrePaciente"
            app:layout_constraintStart_toStartOf="@id/tvNombrePaciente"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>